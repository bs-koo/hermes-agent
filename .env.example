# Google Chat incoming webhook URL (스페이스 → 앱/통합 → 웹훅에서 발급)
# 실제 값은 이 파일을 복사한 .env 에 넣으세요 (.env 는 git 에 커밋되지 않습니다)
GCHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/YOUR_SPACE_ID/messages?key=YOUR_KEY&token=YOUR_TOKEN

# Gemini API 키 (Google AI Studio 무료 발급) — 대시보드 채팅 패널이 사용
# gemini-2.5-flash 무료 한도. GEMINI_API_KEY 와 GOOGLE_API_KEY 중 하나만 있어도 됨.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
